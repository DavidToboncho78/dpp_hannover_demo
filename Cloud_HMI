    c1.metric(label="⚡ Voltage", value=f"{st.session_state.live_dpp_data['voltage']} V")
    c2.metric(label="🔋 Charge (SoC)", value=f"{st.session_state.live_dpp_data['stateOfCharge']} %")
    
    # Put Health on its own full-width line below the others for emphasis
    st.metric(label="❤️ Health (SoH)", value=f"{st.session_state.live_dpp_data['stateOfHealth']} %")

st.divider()

